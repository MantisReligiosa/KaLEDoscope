<UserControl x:Class="PixelBoardDevice.UI.PixelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PixelBoardDevice.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="Black" BorderThickness='0,2,2,0'>
            <Border BorderBrush="LightGray" BorderThickness='10,10,10,10'>
                <Canvas Name="preview" Grid.Row="0" Background="Black" Height="{Binding DeviceHeight}" Width="{Binding DeviceWidth}">
                </Canvas>
            </Border>
        </Border>
    </Grid>
</UserControl>
